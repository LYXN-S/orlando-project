# Environment Configuration Example
# Copy this file to .env and update with your actual values

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=orlando_db
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here_minimum_256_bits
JWT_EXPIRATION=86400000

# Server Configuration
PORT=8080

# CORS Configuration
# Comma-separated list of allowed origins for cross-origin requests
# Format: http://domain:port or https://domain:port (NO trailing slashes)
# 
# Local Development (default if not set):
# ALLOWED_ORIGINS=http://localhost:3000,https://localhost:3000
#
# Staging Environment Example:
# ALLOWED_ORIGINS=https://staging-frontend.example.com,https://staging-app.example.com
#
# Production Environment Example:
# ALLOWED_ORIGINS=https://orlando-frontend-production.up.railway.app,https://orlando-frontend.danielvictorioso03.workers.dev
#
# IMPORTANT: 
# - Do NOT include trailing slashes on URLs
# - Do NOT add spaces between URLs
# - Use HTTPS in production environments
# - Set this variable in your deployment platform (Railway, Docker, etc.)
ALLOWED_ORIGINS=http://localhost:3000,https://localhost:3000
